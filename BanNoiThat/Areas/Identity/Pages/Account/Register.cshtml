@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="min-h-[70vh] flex items-center justify-center py-12 px-6">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-sm border border-outline-variant/35 p-8 space-y-6">
        
        <div class="text-center">
            <h1 class="font-headline text-3xl font-semibold text-primary">DecorHome</h1>
            <p class="text-on-surface-variant text-sm mt-2">Tạo tài khoản mới để bắt đầu trải nghiệm mua sắm</p>
        </div>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="space-y-4">
            <div asp-validation-summary="ModelOnly" class="text-red-600 text-xs font-semibold" role="alert"></div>

            <div class="space-y-1">
                <label asp-for="Input.Email" class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Email</label>
                <input asp-for="Input.Email" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-all bg-surface/30" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="text-red-500 text-xs"></span>
            </div>

            <div class="space-y-1">
                <label asp-for="Input.Password" class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Mật khẩu</label>
                <input asp-for="Input.Password" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-all bg-surface/30" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                <span asp-validation-for="Input.Password" class="text-red-500 text-xs"></span>
            </div>

            <div class="space-y-1">
                <label asp-for="Input.ConfirmPassword" class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Xác nhận mật khẩu</label>
                <input asp-for="Input.ConfirmPassword" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-all bg-surface/30" autocomplete="new-password" aria-required="true" placeholder="••••••••" />
                <span asp-validation-for="Input.ConfirmPassword" class="text-red-500 text-xs"></span>
            </div>

            <button id="registerSubmit" type="submit" class="w-full bg-primary hover:bg-primary-container text-white py-3 rounded-xl font-semibold shadow hover:shadow-md transition-all duration-200 mt-4 cursor-pointer">
                Đăng ký tài khoản
            </button>
        </form>

        <div class="relative flex py-2 items-center">
            <div class="flex-grow border-t border-outline-variant/20"></div>
            <span class="flex-shrink mx-4 text-on-surface-variant/40 text-[10px] uppercase tracking-wider font-semibold">hoặc</span>
            <div class="flex-grow border-t border-outline-variant/20"></div>
        </div>

        <div class="text-center text-sm text-on-surface-variant">
            <span>Đã có tài khoản? </span>
            <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-primary font-semibold hover:underline">Đăng nhập</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

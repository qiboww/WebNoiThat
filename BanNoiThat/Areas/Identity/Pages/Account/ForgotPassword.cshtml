@page
@model ForgotPasswordModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="min-h-[70vh] flex items-center justify-center py-12 px-6">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-sm border border-outline-variant/35 p-8 space-y-6">
        
        <div class="text-center">
            <h1 class="font-headline text-3xl font-semibold text-primary">DecorHome</h1>
            <p class="text-on-surface-variant text-sm mt-2">Nhập email của bạn để nhận liên kết khôi phục mật khẩu</p>
        </div>

        <form method="post" class="space-y-4">
            <div asp-validation-summary="ModelOnly" class="text-red-600 text-xs font-semibold" role="alert"></div>

            <div class="space-y-1">
                <label asp-for="Input.Email" class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Địa chỉ Email</label>
                <input asp-for="Input.Email" class="w-full px-4 py-3 rounded-xl border border-outline-variant/50 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none text-sm transition-all bg-surface/30" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <span asp-validation-for="Input.Email" class="text-red-500 text-xs"></span>
            </div>

            <button type="submit" class="w-full bg-primary hover:bg-primary-container text-white py-3 rounded-xl font-semibold shadow hover:shadow-md transition-all duration-200 mt-4 cursor-pointer">
                Gửi yêu cầu khôi phục
            </button>
        </form>

        <div class="text-center text-sm text-on-surface-variant pt-2 border-t border-outline-variant/10">
            <a asp-page="./Login" class="text-primary font-semibold hover:underline inline-flex items-center gap-1">
                <span class="material-symbols-outlined text-[16px]">arrow_back</span>
                <span>Quay lại đăng nhập</span>
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

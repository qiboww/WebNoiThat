@model IEnumerable<BanNoiThat.Models.Product>

@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<div class="max-w-7xl mx-auto px-6 py-10">
    <partial name="_AdminNav" />

    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
        <div>
            <h1 class="font-headline text-3xl font-semibold text-primary">Quản lý sản phẩm</h1>
            <p class="text-on-surface-variant mt-1 text-sm">Danh sách các sản phẩm nội thất đang kinh doanh trong hệ thống.</p>
        </div>
        <div>
            <a asp-area="Admin" asp-controller="Product" asp-action="Create" class="inline-flex items-center gap-2 bg-primary text-white hover:bg-primary-container px-5 py-2.5 rounded-full font-medium shadow-sm hover:shadow transition-all duration-200">
                <span class="material-symbols-outlined text-[20px]">add</span>
                <span>Thêm sản phẩm mới</span>
            </a>
        </div>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-outline-variant/30 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-secondary-container/30 border-b border-outline-variant/20 text-on-surface-variant text-xs font-semibold uppercase tracking-wider">
                        <th class="py-4 px-6">Hình ảnh</th>
                        <th class="py-4 px-6">Tên sản phẩm</th>
                        <th class="py-4 px-6">Thể loại</th>
                        <th class="py-4 px-6 text-right">Giá bán</th>
                        <th class="py-4 px-6 text-center">Số lượng</th>
                        <th class="py-4 px-6">Chất liệu</th>
                        <th class="py-4 px-6 text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant/20 text-sm">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-surface-variant/10 transition-colors">
                                <td class="py-4 px-6">
                                    <div class="w-14 h-14 rounded-lg overflow-hidden bg-surface-variant/20 border border-outline-variant/30 flex items-center justify-center">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl" alt="@item.Name" class="w-full h-full object-cover" />
                                        }
                                        else
                                        {
                                            <span class="material-symbols-outlined text-on-surface-variant/40">image</span>
                                        }
                                    </div>
                                </td>
                                <td class="py-4 px-6 font-medium text-on-surface">@item.Name</td>
                                <td class="py-4 px-6">
                                    <span class="bg-secondary-container text-primary text-xs px-2.5 py-1 rounded-full font-medium">
                                        @(item.Category?.Name ?? "N/A")
                                    </span>
                                </td>
                                <td class="py-4 px-6 text-right font-semibold text-primary">@item.Price.ToString("N0")₫</td>
                                <td class="py-4 px-6 text-center">
                                    @if (item.StockQuantity > 0)
                                    {
                                        <span class="text-green-600 font-medium">@item.StockQuantity</span>
                                    }
                                    else
                                    {
                                        <span class="text-red-500 font-medium">Hết hàng</span>
                                    }
                                </td>
                                <td class="py-4 px-6 text-on-surface-variant">@item.Material</td>
                                <td class="py-4 px-6">
                                    <div class="flex items-center justify-center gap-3">
                                        <a asp-area="Admin" asp-controller="Product" asp-action="Details" asp-route-id="@item.ProductId" class="text-on-surface-variant hover:text-primary p-1 rounded hover:bg-surface-variant/20 transition-colors" title="Xem chi tiết">
                                            <span class="material-symbols-outlined text-[20px]">visibility</span>
                                        </a>
                                        <a asp-area="Admin" asp-controller="Product" asp-action="Edit" asp-route-id="@item.ProductId" class="text-primary hover:text-primary-container p-1 rounded hover:bg-surface-variant/20 transition-colors" title="Sửa">
                                            <span class="material-symbols-outlined text-[20px]">edit</span>
                                        </a>
                                        <a asp-area="Admin" asp-controller="Product" asp-action="Delete" asp-route-id="@item.ProductId" class="text-red-600 hover:text-red-500 p-1 rounded hover:bg-red-50 transition-colors" title="Xóa">
                                            <span class="material-symbols-outlined text-[20px]">delete</span>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="py-10 px-6 text-center text-on-surface-variant">
                                <span class="material-symbols-outlined text-4xl text-on-surface-variant/30 block mb-2">inventory_2</span>
                                Không có sản phẩm nào được tìm thấy.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@model BanNoiThat.Models.Product

@{
    ViewData["Title"] = "Chỉnh sửa sản phẩm - " + Model.Name;
}

<div class="max-w-3xl mx-auto px-6 py-10">
    <div class="mb-8">
        <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="inline-flex items-center gap-1.5 text-on-surface-variant hover:text-primary transition-colors text-sm font-medium mb-4">
            <span class="material-symbols-outlined text-[18px]">arrow_back</span>
            <span>Quay lại danh sách</span>
        </a>
        <h1 class="font-headline text-3xl font-semibold text-primary">Chỉnh sửa sản phẩm</h1>
        <p class="text-on-surface-variant mt-1 text-sm">Chỉnh sửa thông tin chi tiết của sản phẩm nội thất bên dưới.</p>
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-outline-variant/30 p-6 md:p-8">
        <form asp-area="Admin" asp-controller="Product" asp-action="Edit" method="post" enctype="multipart/form-data" class="space-y-6">
            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm font-medium"></div>
            
            <!-- Hidden Fields -->
            <input type="hidden" asp-for="ProductId" />
            <input type="hidden" asp-for="ImageUrl" />
            <input type="hidden" asp-for="Model3DUrl" />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Tên sản phẩm -->
                <div class="md:col-span-2">
                    <label asp-for="Name" class="block text-sm font-medium text-on-surface mb-2">Tên sản phẩm <span class="text-red-500">*</span></label>
                    <input asp-for="Name" type="text" placeholder="Ví dụ: Bàn ăn gỗ sồi Helsinki" class="w-full px-4 py-2.5 rounded-lg border border-outline-variant focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 text-sm transition-all" />
                    <span asp-validation-for="Name" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Danh mục sản phẩm -->
                <div>
                    <label asp-for="CategoryId" class="block text-sm font-medium text-on-surface mb-2">Danh mục <span class="text-red-500">*</span></label>
                    <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="w-full px-4 py-2.5 rounded-lg border border-outline-variant focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 text-sm bg-white transition-all">
                        <option value="">-- Chọn danh mục --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Chất liệu -->
                <div>
                    <label asp-for="Material" class="block text-sm font-medium text-on-surface mb-2">Chất liệu</label>
                    <input asp-for="Material" type="text" placeholder="Ví dụ: Gỗ sồi tự nhiên" class="w-full px-4 py-2.5 rounded-lg border border-outline-variant focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 text-sm transition-all" />
                    <span asp-validation-for="Material" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Giá bán -->
                <div>
                    <label asp-for="Price" class="block text-sm font-medium text-on-surface mb-2">Giá bán (₫) <span class="text-red-500">*</span></label>
                    <input asp-for="Price" type="number" min="0" step="any" placeholder="Ví dụ: 12500000" class="w-full px-4 py-2.5 rounded-lg border border-outline-variant focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 text-sm transition-all" />
                    <span asp-validation-for="Price" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Số lượng tồn -->
                <div>
                    <label asp-for="StockQuantity" class="block text-sm font-medium text-on-surface mb-2">Số lượng kho <span class="text-red-500">*</span></label>
                    <input asp-for="StockQuantity" type="number" min="0" placeholder="Ví dụ: 10" class="w-full px-4 py-2.5 rounded-lg border border-outline-variant focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 text-sm transition-all" />
                    <span asp-validation-for="StockQuantity" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <!-- Ảnh hiện tại -->
                <div class="md:col-span-2">
                    <label class="block text-sm font-medium text-on-surface mb-2">Hình ảnh hiện tại</label>
                    <div class="flex items-center gap-4">
                        <div class="w-20 h-20 rounded-lg overflow-hidden border border-outline-variant bg-surface-variant/20 flex items-center justify-center">
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img src="@Model.ImageUrl" alt="@Model.Name" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <span class="material-symbols-outlined text-on-surface-variant/30 text-3xl">image</span>
                            }
                        </div>
                        <div class="text-xs text-on-surface-variant">
                            Nếu bạn không muốn thay đổi ảnh, vui lòng bỏ trống phần "Tải lên ảnh mới" bên dưới.
                        </div>
                    </div>
                </div>

                <!-- Tải lên ảnh mới -->
                <div class="md:col-span-2">
                    <label for="imageFile" class="block text-sm font-medium text-on-surface mb-2">Tải lên ảnh mới</label>
                    <input id="imageFile" name="imageFile" type="file" accept="image/*" class="w-full px-4 py-2 rounded-lg border border-outline-variant focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 text-sm bg-white file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-primary/10 file:text-primary hover:file:bg-primary/20 transition-all cursor-pointer" />
                    <p class="text-xs text-on-surface-variant mt-1">Chọn file ảnh mới để thay đổi ảnh hiện tại của sản phẩm.</p>
                </div>

                <!-- Mô hình 3D hiện tại -->
                <div class="md:col-span-2">
                    <label class="block text-sm font-medium text-on-surface mb-2">Mô hình 3D hiện tại</label>
                    <div class="flex items-center gap-4">
                        <div class="w-20 h-20 rounded-lg overflow-hidden border border-outline-variant bg-surface-variant/20 flex items-center justify-center">
                            @if (!string.IsNullOrEmpty(Model.Model3DUrl))
                            {
                                <span class="material-symbols-outlined text-primary text-3xl">view_in_ar</span>
                            }
                            else
                            {
                                <span class="material-symbols-outlined text-on-surface-variant/30 text-3xl">view_in_ar</span>
                            }
                        </div>
                        <div class="text-xs text-on-surface-variant">
                            @if (!string.IsNullOrEmpty(Model.Model3DUrl))
                            {
                                <span class="text-green-600 font-semibold">Đã tải lên mô hình 3D (@Model.Model3DUrl.Split('/').Last())</span>
                            }
                            else
                            {
                                <span>Chưa có mô hình 3D cho sản phẩm này.</span>
                            }
                            <div class="mt-1 text-on-surface-variant/70">
                                Nếu không muốn thay đổi mô hình 3D, vui lòng bỏ trống phần "Tải lên mô hình 3D mới" bên dưới.
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tải lên mô hình 3D mới -->
                <div class="md:col-span-2">
                    <label for="model3dFile" class="block text-sm font-medium text-on-surface mb-2">Tải lên mô hình 3D mới (.glb)</label>
                    <input id="model3dFile" name="model3dFile" type="file" accept=".glb" class="w-full px-4 py-2 rounded-lg border border-outline-variant focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 text-sm bg-white file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-primary/10 file:text-primary hover:file:bg-primary/20 transition-all cursor-pointer" />
                    <p class="text-xs text-on-surface-variant mt-1">Chọn file mô hình 3D (.glb) mới để thay thế mô hình 3D hiện tại.</p>
                </div>

                <!-- Mô tả sản phẩm -->
                <div class="md:col-span-2">
                    <label asp-for="Description" class="block text-sm font-medium text-on-surface mb-2">Mô tả sản phẩm</label>
                    <textarea asp-for="Description" rows="4" placeholder="Nhập mô tả chi tiết sản phẩm tại đây..." class="w-full px-4 py-2.5 rounded-lg border border-outline-variant focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary/20 text-sm transition-all resize-y"></textarea>
                    <span asp-validation-for="Description" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>

            <!-- Các nút hành động -->
            <div class="flex items-center justify-end gap-4 pt-4 border-t border-outline-variant/30">
                <a asp-area="Admin" asp-controller="Product" asp-action="Index" class="px-5 py-2.5 rounded-full border border-outline-variant hover:bg-surface-variant/25 font-medium text-sm text-on-surface transition-all">
                    Hủy bỏ
                </a>
                <button type="submit" class="px-6 py-2.5 rounded-full bg-primary hover:bg-primary-container text-white font-medium text-sm shadow-sm hover:shadow transition-all">
                    Cập nhật sản phẩm
                </button>
            </div>
        </form>
    </div>
</div>

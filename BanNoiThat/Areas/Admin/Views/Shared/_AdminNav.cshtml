@{
    var controller = ViewContext.RouteData.Values["controller"]?.ToString();
}

<div class="flex gap-2 border-b border-outline-variant/20 mb-8">
    <a asp-area="Admin" asp-controller="Product" asp-action="Index" 
       class="px-4 py-2.5 font-medium text-sm transition-all relative @(controller == "Product" ? "text-primary border-b-2 border-primary" : "text-on-surface-variant hover:text-primary")">
        <span class="flex items-center gap-1.5">
            <span class="material-symbols-outlined text-[18px]">inventory_2</span>
            <span>Quản lý sản phẩm</span>
        </span>
    </a>
    <a asp-area="Admin" asp-controller="Category" asp-action="Index" 
       class="px-4 py-2.5 font-medium text-sm transition-all relative @(controller == "Category" ? "text-primary border-b-2 border-primary" : "text-on-surface-variant hover:text-primary")">
        <span class="flex items-center gap-1.5">
            <span class="material-symbols-outlined text-[18px]">folder</span>
            <span>Quản lý danh mục</span>
        </span>
    </a>
    <a asp-area="Admin" asp-controller="Order" asp-action="Index" 
       class="px-4 py-2.5 font-medium text-sm transition-all relative @(controller == "Order" ? "text-primary border-b-2 border-primary" : "text-on-surface-variant hover:text-primary")">
        <span class="flex items-center gap-1.5">
            <span class="material-symbols-outlined text-[18px]">shopping_bag</span>
            <span>Quản lý đơn hàng</span>
        </span>
    </a>
    <a asp-area="Admin" asp-controller="User" asp-action="Index" 
       class="px-4 py-2.5 font-medium text-sm transition-all relative @(controller == "User" ? "text-primary border-b-2 border-primary" : "text-on-surface-variant hover:text-primary")">
        <span class="flex items-center gap-1.5">
            <span class="material-symbols-outlined text-[18px]">people</span>
            <span>Quản lý người dùng</span>
        </span>
    </a>
</div>

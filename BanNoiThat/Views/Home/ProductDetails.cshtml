@model BanNoiThat.Models.Product

@{
    ViewData["Title"] = Model.Name + " - DecorHome";
}

<div class="max-w-6xl mx-auto px-6 py-12">
    <!-- Nút quay lại -->
    <div class="mb-6">
        <a asp-controller="Home" asp-action="Products" class="inline-flex items-center gap-1.5 text-on-surface-variant hover:text-primary transition-colors text-sm font-medium">
            <span class="material-symbols-outlined text-[18px]">arrow_back</span>
            <span>Quay lại cửa hàng</span>
        </a>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-outline-variant/20 overflow-hidden p-6 md:p-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
            <!-- Hình ảnh sản phẩm / Trình xem 3D (bên trái) -->
            <div class="aspect-square w-full rounded-xl overflow-hidden bg-surface-variant/20 border border-outline-variant/30 flex items-center justify-center relative group">
                @if (!string.IsNullOrEmpty(Model.Model3DUrl))
                {
                    <!-- Chuyển đổi chế độ xem -->
                    <div class="absolute top-4 right-4 z-10 flex bg-white/90 backdrop-blur border border-outline-variant/40 rounded-full p-1 shadow-sm transition-all duration-200 opacity-90 group-hover:opacity-100">
                        <button id="btn-view-2d" class="px-3.5 py-1.5 rounded-full text-xs font-semibold flex items-center gap-1 bg-primary text-white transition-all shadow-sm">
                            <span class="material-symbols-outlined text-[16px]">image</span>
                            <span>Ảnh 2D</span>
                        </button>
                        <button id="btn-view-3d" class="px-3.5 py-1.5 rounded-full text-xs font-semibold flex items-center gap-1 text-on-surface-variant hover:text-primary transition-all">
                            <span class="material-symbols-outlined text-[16px]">view_in_ar</span>
                            <span>Mô hình 3D</span>
                        </button>
                    </div>

                    <!-- Chế độ xem ảnh 2D -->
                    <div id="container-2d" class="w-full h-full">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" alt="@Model.Name" class="w-full h-full object-cover" />
                        }
                        else
                        {
                            <div class="flex flex-col items-center justify-center text-on-surface-variant/30 h-full">
                                <span class="material-symbols-outlined text-8xl block mb-2">image</span>
                                <span class="text-sm">Chưa cập nhật hình ảnh</span>
                            </div>
                        }
                    </div>

                    <!-- Chế độ xem mô hình 3D -->
                    <div id="container-3d" class="w-full h-full hidden">
                        <model-viewer src="@Model.Model3DUrl"
                                      alt="Mô hình 3D của @Model.Name"
                                      camera-controls
                                      auto-rotate
                                      ar
                                      shadow-intensity="1"
                                      touch-action="pan-y"
                                      class="w-full h-full bg-transparent"
                                      style="width: 100%; height: 100%;">
                        </model-viewer>
                    </div>
                }
                else
                {
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.Name" class="w-full h-full object-cover" />
                    }
                    else
                    {
                        <div class="flex flex-col items-center justify-center text-on-surface-variant/30 w-full h-full">
                            <span class="material-symbols-outlined text-8xl block mb-2">image</span>
                            <span class="text-sm">Chưa cập nhật hình ảnh</span>
                        </div>
                    }
                }
            </div>

            <!-- Thông tin chi tiết (bên phải) -->
            <div class="flex flex-col justify-between h-full space-y-8">
                <div class="space-y-6">
                    <div>
                        <span class="bg-secondary-container text-primary text-xs px-3 py-1.5 rounded-full font-semibold uppercase tracking-wider">
                            @(Model.Category?.Name ?? "Nội thất")
                        </span>
                        <h1 class="font-headline text-3xl md:text-4xl font-semibold text-on-surface mt-3">@Model.Name</h1>
                    </div>

                    <div class="border-t border-b border-outline-variant/20 py-5">
                        <div class="text-xs text-on-surface-variant uppercase tracking-wider font-semibold">Giá bán lẻ</div>
                        <div class="text-4xl font-semibold text-primary mt-1">@Model.Price.ToString("N0")₫</div>
                    </div>

                    <!-- Thông số phụ -->
                    <div class="grid grid-cols-2 gap-4 text-sm">
                        <div class="bg-surface-variant/10 p-4 rounded-xl border border-outline-variant/20">
                            <div class="text-xs text-on-surface-variant font-medium">Chất liệu chính</div>
                            <div class="text-on-surface font-semibold mt-1">@(string.IsNullOrEmpty(Model.Material) ? "Đang cập nhật" : Model.Material)</div>
                        </div>
                        <div class="bg-surface-variant/10 p-4 rounded-xl border border-outline-variant/20">
                            <div class="text-xs text-on-surface-variant font-medium">Tình trạng kho</div>
                            <div class="font-semibold mt-1 @(Model.StockQuantity > 0 ? "text-green-600" : "text-red-500")">
                                @(Model.StockQuantity > 0 ? $"Còn hàng ({Model.StockQuantity} chiếc)" : "Hết hàng")
                            </div>
                        </div>
                    </div>

                    <!-- Mô tả sản phẩm -->
                    <div class="space-y-2.5">
                        <h3 class="text-sm font-semibold text-on-surface uppercase tracking-wider">Mô tả sản phẩm</h3>
                        <p class="text-sm text-on-surface-variant leading-relaxed whitespace-pre-wrap">@(string.IsNullOrEmpty(Model.Description) ? "Hiện chưa có thông tin mô tả chi tiết cho sản phẩm này từ DecorHome." : Model.Description)</p>
                    </div>
                </div>

                <!-- Nút Thêm vào giỏ -->
                <div class="pt-6 border-t border-outline-variant/20">
                    @if (Model.StockQuantity > 0)
                    {
                        <button class="w-full bg-primary hover:bg-primary-container text-white py-3 px-6 rounded-full font-semibold shadow hover:shadow-md transition-all duration-200 flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined">shopping_cart</span>
                            <span>Thêm vào giỏ hàng</span>
                        </button>
                    }
                    else
                    {
                        <button disabled class="w-full bg-on-surface-variant/20 text-on-surface-variant/60 py-3 px-6 rounded-full font-semibold cursor-not-allowed flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined">inventory_2</span>
                            <span>Sản phẩm tạm hết hàng</span>
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Model3DUrl))
{
    @section Scripts {
        <script type="module" src="https://ajax.googleapis.com/ajax/libs/model-viewer/3.5.0/model-viewer.min.js"></script>
        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const btn2d = document.getElementById("btn-view-2d");
                const btn3d = document.getElementById("btn-view-3d");
                const container2d = document.getElementById("container-2d");
                const container3d = document.getElementById("container-3d");

                if (btn2d && btn3d && container2d && container3d) {
                    btn2d.addEventListener("click", () => {
                        // Switch tab active styling
                        btn2d.classList.add("bg-primary", "text-white", "shadow-sm");
                        btn2d.classList.remove("text-on-surface-variant", "hover:text-primary");
                        
                        btn3d.classList.remove("bg-primary", "text-white", "shadow-sm");
                        btn3d.classList.add("text-on-surface-variant", "hover:text-primary");
                        
                        // Show/hide container
                        container2d.classList.remove("hidden");
                        container3d.classList.add("hidden");
                    });

                    btn3d.addEventListener("click", () => {
                        // Switch tab active styling
                        btn3d.classList.add("bg-primary", "text-white", "shadow-sm");
                        btn3d.classList.remove("text-on-surface-variant", "hover:text-primary");
                        
                        btn2d.classList.remove("bg-primary", "text-white", "shadow-sm");
                        btn2d.classList.add("text-on-surface-variant", "hover:text-primary");
                        
                        // Show/hide container
                        container3d.classList.remove("hidden");
                        container2d.classList.add("hidden");
                    });
                }
            });
        </script>
    }
}

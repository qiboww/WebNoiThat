@model IEnumerable<BanNoiThat.Models.Product>

@{
    ViewData["Title"] = "Sản phẩm";
    var categories = ViewBag.Categories as IEnumerable<BanNoiThat.Models.Category>;
    var selectedCategoryId = ViewBag.SelectedCategoryId as int?;
}

<div class="max-w-7xl mx-auto px-6 py-12">
    <!-- Header của trang -->
    <div class="text-center max-w-xl mx-auto mb-12">
        <h1 class="font-headline text-4xl font-semibold text-primary">Bộ sưu tập nội thất</h1>
        <div class="h-0.5 w-12 bg-primary mx-auto mt-4 rounded"></div>
        <p class="text-on-surface-variant mt-4 text-sm">
            @if (ViewBag.CategoryName != null)
            {
                <span>Khám phá các sản phẩm độc đáo thuộc danh mục <strong>@ViewBag.CategoryName</strong> của chúng tôi.</span>
            }
            else
            {
                <span>Khám phá toàn bộ sản phẩm thiết kế tối giản, tinh tế mang phong cách Bắc Âu.</span>
            }
        </p>
    </div>

    <div class="flex flex-col lg:flex-row gap-10">
        <!-- Sidebar lọc danh mục (bên trái) -->
        <aside class="w-full lg:w-64 flex-shrink-0 space-y-6">
            <div class="border border-outline-variant/35 rounded-xl bg-white p-6">
                <h3 class="font-headline text-lg font-semibold text-primary mb-4 pb-2 border-b border-outline-variant/20">
                    Danh mục
                </h3>
                <ul class="space-y-2 text-sm">
                    <li>
                        <a asp-controller="Home" asp-action="Products" asp-route-categoryId="" 
                           class="flex items-center justify-between px-3 py-2 rounded-lg transition-colors @(selectedCategoryId == null ? "bg-primary text-white font-medium shadow-sm" : "text-on-surface-variant hover:bg-surface-variant/20 hover:text-primary")">
                            <span>Tất cả sản phẩm</span>
                            <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                        </a>
                    </li>
                    @if (categories != null)
                    {
                        @foreach (var cat in categories)
                        {
                            <li>
                                <a asp-controller="Home" asp-action="Products" asp-route-categoryId="@cat.CategoryId" 
                                   class="flex items-center justify-between px-3 py-2 rounded-lg transition-colors @(selectedCategoryId == cat.CategoryId ? "bg-primary text-white font-medium shadow-sm" : "text-on-surface-variant hover:bg-surface-variant/20 hover:text-primary")">
                                    <span>@cat.Name</span>
                                    <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                                </a>
                            </li>
                        }
                    }
                </ul>
            </div>
        </aside>

        <!-- Lưới danh sách sản phẩm (bên phải) -->
        <main class="flex-grow">
            @if (Model != null && Model.Any())
            {
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
                    @foreach (var item in Model)
                    {
                        <div class="group bg-white rounded-xl shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden border border-outline-variant/20 flex flex-col h-full">
                            <!-- Ảnh sản phẩm -->
                            <a asp-controller="Home" asp-action="ProductDetails" asp-route-id="@item.ProductId" class="aspect-square w-full overflow-hidden bg-surface-variant/20 relative block">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Name" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                                }
                                else
                                {
                                    <div class="w-full h-full flex items-center justify-center text-on-surface-variant/30">
                                        <span class="material-symbols-outlined text-5xl">image</span>
                                    </div>
                                }
                            </a>

                            <!-- Thông tin sản phẩm -->
                            <div class="p-5 flex flex-col flex-grow">
                                <div class="text-[10px] text-primary font-semibold uppercase tracking-wider mb-1">
                                    @(item.Category?.Name ?? "Nội thất")
                                </div>
                                <h3 class="font-headline text-lg font-semibold text-on-surface mb-1 hover:text-primary transition-colors">
                                    <a asp-controller="Home" asp-action="ProductDetails" asp-route-id="@item.ProductId">@item.Name</a>
                                </h3>
                                <div class="text-xs text-on-surface-variant mb-4 font-medium">Chất liệu: @(string.IsNullOrEmpty(item.Material) ? "Đang cập nhật" : item.Material)</div>
                                
                                <div class="flex items-center justify-between mt-auto pt-4 border-t border-outline-variant/20">
                                    <div class="font-semibold text-primary text-lg">@item.Price.ToString("N0")₫</div>
                                    <a asp-controller="Home" asp-action="ProductDetails" asp-route-id="@item.ProductId" class="text-xs font-semibold text-primary hover:text-primary-container inline-flex items-center gap-0.5 border border-primary/25 rounded-full px-3.5 py-1.5 hover:bg-primary/5 transition-all">
                                        <span>Xem chi tiết</span>
                                        <span class="material-symbols-outlined text-[14px]">arrow_forward</span>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="text-center py-20 bg-white rounded-xl border border-outline-variant/30 text-on-surface-variant/60">
                    <span class="material-symbols-outlined text-6xl block mb-4 text-on-surface-variant/30">inventory_2</span>
                    <h3 class="text-lg font-semibold text-on-surface mb-1">Chưa có sản phẩm nào</h3>
                    <p class="text-sm">Không tìm thấy sản phẩm nào trong danh mục này.</p>
                </div>
            }
        </main>
    </div>
</div>

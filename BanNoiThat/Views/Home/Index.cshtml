@model IEnumerable<BanNoiThat.Models.Category>
@{
    ViewData["Title"] = "Trang chủ";
}

<section class="h-[60vh] bg-cover bg-center flex items-center justify-center relative"
         style="background-image: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), url('/images/hero.jpg');">
    <div class="text-center text-white px-6">
        <h1 class="font-headline text-4xl md:text-6xl font-semibold mb-4 drop-shadow">Không Gian Sống Tối Giản</h1>
        <p class="text-lg md:text-xl font-light max-w-xl mx-auto drop-shadow-sm">Khám phá bộ sưu tập nội thất cao cấp mang phong cách Bắc Âu ấm cúng và sang trọng.</p>
    </div>
</section>

<section class="py-20 bg-surface">
    <div class="max-w-7xl mx-auto px-6">
        <div class="text-center max-w-xl mx-auto mb-16">
            <h2 class="font-headline text-3xl font-semibold text-primary">Danh mục sản phẩm</h2>
            <div class="h-0.5 w-12 bg-primary mx-auto mt-4 rounded"></div>
            <p class="text-on-surface-variant mt-4 text-sm">Lựa chọn các sản phẩm nội thất được phân loại thiết kế tối giản, tinh tế cho từng không gian sống của bạn.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <div class="group bg-white rounded-xl shadow-sm hover:shadow-lg transition-all duration-300 overflow-hidden border border-outline-variant/20 flex flex-col h-full">
                        <div class="aspect-[4/3] w-full overflow-hidden bg-surface-variant/20 relative">
                            @if (!string.IsNullOrEmpty(item.ImageUrl))
                            {
                                <img src="@item.ImageUrl" alt="@item.Name" loading="lazy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                            }
                            else
                            {
                                <div class="w-full h-full flex items-center justify-center text-on-surface-variant/30">
                                    <span class="material-symbols-outlined text-5xl">folder</span>
                                </div>
                            }
                        </div>
                        <div class="p-6 flex flex-col flex-grow">
                            <h3 class="font-headline text-xl font-semibold text-on-surface mb-2 group-hover:text-primary transition-colors">@item.Name</h3>
                            <a asp-area="" asp-controller="Home" asp-action="Products" asp-route-categoryId="@item.CategoryId" class="inline-flex items-center gap-1 text-primary hover:text-primary-container text-sm font-semibold transition-colors mt-auto">
                                <span>Khám phá</span>
                                <span class="material-symbols-outlined text-[16px]">arrow_forward</span>
                            </a>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-span-full text-center py-12 text-on-surface-variant/60">
                    <span class="material-symbols-outlined text-5xl block mb-3 text-on-surface-variant/30">category</span>
                    Chưa có danh mục sản phẩm nào được thiết lập.
                </div>
            }
        </div>
    </div>
</section>